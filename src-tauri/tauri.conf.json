{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GridDown",
  "version": "0.1.0",
  "identifier": "com.griddown.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GridDown",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENEOEY1RTY4MEFBRkJGMEIKUldRTHY2OEthRjZQellYSnVoaFpTSU5LWmMxK2ZrR2NrdFRUNk5wekVBV0I5UmVTbVJ5eHNBMnUK",
      "endpoints": [
        "https://github.com/pl0xuee/griddown/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/pmtiles"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
