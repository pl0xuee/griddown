# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# The Xcode project, regenerated by `tauri ios init` on every CI run.
# Committing it would only create drift against Info.ios.plist, which is the
# actual source of truth for anything we care about in there.
/gen/apple
